<UserControl x:Class="TextilePro.UI.Views.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TextilePro.UI.Converters"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:IdToStatusConverter x:Key="IdToStatusConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,16">
            <TextBlock Text="🏭 Supplier Management"
                    FontSize="22"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Foreground="#1a1a1a"/>
            <Button Content="➕ New Supplier"
                    Command="{Binding NewSupplierCommand}"
                    Background="#0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="14,8"
                    Margin="20,0,0,0"
                    FontWeight="SemiBold"
                    FontSize="14"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>
            <TextBlock Text="(Select a supplier from the left to edit)"
                       FontSize="12"
                    Foreground="#888888"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Supplier List -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Background="White"
                    Padding="12"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                            Margin="0,0,0,12">
                        <TextBlock Text="📋 Supplier List"
                                FontWeight="Bold"
                                FontSize="14"
                                Foreground="#333333"
                                Margin="0,0,0,8"/>
                        <Grid>
                            <TextBox x:Name="SearchBox"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    
                                     FontSize="13"
                                    Background="#FAFAFA"/>
                            <TextBlock Text="🔍 Search suppliers..."
                                    FontSize="13"
                                    Foreground="#AAAAAA"
                                       Padding="8,0,0,0"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                       Visibility="{Binding ElementName=SearchBox, Path=Text, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>

                        <ListBox Grid.Row="1"
                            ItemsSource="{Binding Suppliers}"
                             SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                             Background="Transparent"
                            BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"
                                        Value="10,8"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                                <Setter Property="Background"
                                        Value="Transparent"/>
                                <Setter Property="BorderThickness"
                                        Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"
                                        Value="#EEEEEE"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected"
                                            Value="True">
                                        <Setter Property="Background"
                                                Value="#E5F1FB"/>
                                        <Setter Property="BorderBrush"
                                                Value="#0078D4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver"
                                            Value="True">
                                        <Setter Property="Background"
                                                Value="#F0F7FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <!-- ListBox ItemTemplate -->
<ListBox.ItemTemplate>
    <DataTemplate>
        <StackPanel>
            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding Country, StringFormat='{}📍 {0}'}" FontSize="11" Foreground="#666"/>
            <TextBlock Text="{Binding Contacts.Count, StringFormat='📞 {0} contact(s)'}" FontSize="10" Foreground="#888"/>
        </StackPanel>
    </DataTemplate>
</ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="1"
                            Text="No suppliers yet. Click 'New Supplier' to add one."
                               FontSize="12"
                            Foreground="#999999"
                               HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                               Visibility="{Binding Suppliers.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Right: Edit Form -->
            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    
                    Background="White"
                    Padding="20"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <StackPanel Grid.Row="0"
                                Margin="0,0,0,16">
                            <TextBlock Text="{Binding SelectedSupplier.Name, FallbackValue='📝 New Supplier'}"
                                       FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="#1a1a1a"/>
                            <TextBlock Text="{Binding SelectedSupplier.Id, Converter={StaticResource IdToStatusConverter}, FallbackValue='New'}"
                                       FontSize="11"
                                    Foreground="#888888"/>
                        </StackPanel>

                        <!-- Supplier Information -->
                        <Border Grid.Row="1"
                                Margin="0,0,0,16"
                                Padding="0,0,0,12"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#E0E0E0">
                            <StackPanel>
                                <TextBlock Text="🏢 Supplier Information"
                                        FontWeight="Bold"
                                        FontSize="14"
                                        Foreground="#333333"
                                        Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                            Text="Name *"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Foreground="#333333"/>
                                    <TextBox Grid.Column="1"
                                            Text="{Binding SelectedSupplier.Name, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1"
                                            
                                             FontSize="13"
                                            Background="White"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                            Text="Country"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Foreground="#333333"/>
                                    <TextBox Grid.Column="1"
                                            Text="{Binding SelectedSupplier.Country, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1"
                                           
                                             FontSize="13"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                            Text="Address"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Top"
                                            Foreground="#333333"
                                            Margin="0,4,0,0"/>
                                    <TextBox Grid.Column="1"
                                            Text="{Binding SelectedSupplier.Address, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1"
                                            
                                             AcceptsReturn="True"
                                            Height="60"
                                            TextWrapping="Wrap"
                                             FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Contacts Section -->
                        <Border Grid.Row="2"
                                Margin="0,0,0,12"
                                Padding="0,8,0,0"
                                BorderThickness="0,1,0,0"
                                BorderBrush="#E0E0E0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="📞 Contacts"
                                            FontWeight="Bold"
                                            FontSize="14"
                                            Foreground="#333333"/>
                                    <TextBlock Text="Add one or more contacts for this supplier"
                                            FontSize="11"
                                            Foreground="#888888"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="➕ Add Contact"
                                        Command="{Binding AddContactCommand}"
                                        Background="#E8F0FE"
                                        Foreground="#0078D4"
                                        BorderThickness="1"
                                        BorderBrush="#0078D4"
                                        Padding="12,6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Margin="0,0,0,8">
                                    <Button.Resources>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                
                                                                Padding="{TemplateBinding Padding}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Contacts DataGrid -->
                        <Border Grid.Row="3"
                                Margin="0,0,0,12"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                               >
                            <DataGrid ItemsSource="{Binding Contacts}"
                                      AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      Background="White"
                                    BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      RowHeight="32"
                                      FontSize="13">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Contact Name"
                                            Binding="{Binding ContactName}"
                                            Width="*"/>
                                    <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}"
                                            Width="*"/>
                                    <DataGridTextColumn Header="Phone"
                                            Binding="{Binding Phone}"
                                            Width="120"/>
                                    <DataGridTextColumn Header="Website"
                                            Binding="{Binding Website}"
                                            Width="120"/>
                                    <DataGridTemplateColumn Header=""
                                            Width="40">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✖"
                                                        Command="{Binding DataContext.RemoveContactCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#E81123"
                                                        FontWeight="Bold"
                                                        FontSize="14"
                                                        Cursor="Hand"
                                                        ToolTip="Remove contact"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="6"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <Button Content="💾 Save Supplier"
                                    Command="{Binding SaveSupplierCommand}"
                                    Background="#0078D4"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="20,10"
                                    Margin="0,0,12,0"
                                    Cursor="Hand"
                                    FontWeight="SemiBold"
                                    FontSize="14">
                                <Button.Resources>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="🗑️ Delete"
                                    Command="{Binding DeleteSupplierCommand}"
                                    CommandParameter="{Binding SelectedSupplier}"
                                    Background="#E81123"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="20,10"
                                    Cursor="Hand"
                                    FontWeight="SemiBold"
                                    FontSize="14">
                                <Button.Resources>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>