<Window x:Class="TextilePro.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Winsome Textile - Login"
        Height="350" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Winsome Textile" 
                       FontSize="20" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Commodity Chemicals Management System" 
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <Label Content="Username" FontWeight="Bold"/>
            <TextBox x:Name="UsernameBox" 
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,10"/>

            <Label Content="Password" FontWeight="Bold"/>
            <PasswordBox x:Name="PasswordBox" 
                         Margin="0,0,0,20"/>

            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="Red" 
                       FontSize="12"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Login" 
                        Command="{Binding LoginCommand}" 
                        Width="100" 
                        Margin="0,0,10,0"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource BoolNegationConverter}}"/>
                <Button Content="Exit" 
                        Command="{Binding ExitApplicationCommand}" 
                        Width="100"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>