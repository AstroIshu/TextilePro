<UserControl x:Class="TextilePro.UI.Views.ClassificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TextilePro.UI.Converters"
             Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,16">
            <TextBlock Text="🏷️ Supplier Classification Matrix"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#1a1a1a"
                    VerticalAlignment="Center"/>
            <TextBlock Text="(Supplier performance &amp; risk assessment)"
                    FontSize="12"
                    Foreground="#888888"
                    VerticalAlignment="Center"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Border Grid.Row="1"
               
                Background="White"
                Padding="16"
                BorderBrush="#D0D0D0"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter Bar -->
                <Border Grid.Row="0"
                        Margin="0,0,0,16"
                        Padding="0,0,0,12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#E0E0E0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                Grid.Column="0"
                                Text="🔍 Filters"
                                FontWeight="Bold"
                                FontSize="14"
                                Foreground="#333"
                                Margin="0,0,20,8"/>

                        <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="0,0,20,0">
                            <TextBlock Text="Class:"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding ClassFilterOptions}"
                                      SelectedItem="{Binding SelectedClassFilter}"
                                      Width="100"
                                    Padding="4"
                                    FontSize="12"
                                      Background="White"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,0,20,0">
                            <TextBlock Text="Supplier:"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding SupplierNames}"
                                      SelectedItem="{Binding SelectedSupplier}"
                                      Width="150"
                                    Padding="4"
                                    FontSize="12"
                                      Background="White"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                   >
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBox">
                                                    <Grid>
                                                        <ToggleButton x:Name="ToggleButton"
                                                                      Grid.ColumnSpan="2"
                                                                      Focusable="False"
                                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      Background="White"
                                                                      BorderBrush="#CCCCCC"
                                                                      BorderThickness="1"
                                                                  >
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border Background="{TemplateBinding Background}"
                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                                      >
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="20"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <ContentPresenter Grid.Column="0"
                                                                                                          Content="{TemplateBinding Content}"
                                                                                                          Margin="8,4"
                                                                                                          VerticalAlignment="Center"/>
                                                                                        <Path Grid.Column="1"
                                                                                              Data="M0,0 L5,5 L10,0"
                                                                                              Stroke="#666"
                                                                                              StrokeThickness="2"
                                                                                              HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                        <Popup x:Name="Popup"
                                                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                               PlacementTarget="{Binding ElementName=ToggleButton}"
                                                               StaysOpen="False">
                                                            <Border Background="White"
                                                                    BorderBrush="#CCCCCC"
                                                                    BorderThickness="1"
                                                                  
                                                                    Padding="4"
                                                                    MaxHeight="200">
                                                                <ScrollViewer>
                                                                    <ItemsPresenter/>
                                                                </ScrollViewer>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Margin="0,0,20,0">
                            <TextBlock Text="Product:"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <TextBox Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200"
                                    Padding="8,4"
                                    FontSize="12"
                                     Background="White"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                   />
                        </StackPanel>

                        <Button Grid.Row="1"
                                Grid.Column="3"
                                Content="✖ Clear Filters"
                                Command="{Binding ClearFiltersCommand}"
                                Background="#F5F5F5"
                                Foreground="#333"
                                BorderThickness="0"
                                Padding="12,6"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Data Grid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ClassificationItems}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          Background="White"
                        BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          RowHeight="35"
                          FontSize="13"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F9F9F9">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"
                                    Value="8,4"/>
                            <Setter Property="VerticalAlignment"
                                    Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Supplier Name"
                                Binding="{Binding SupplierName}"
                                Width="2*"/>
                        <DataGridTextColumn Header="Product"
                                Binding="{Binding ProductName}"
                                Width="*"/>
                        <DataGridTextColumn Header="Score"
                                Binding="{Binding Score}"
                            Width="80"/>

                        <DataGridTemplateColumn Header="Class"
                            Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,2"
                                            HorizontalAlignment="Center"
                                            MinWidth="50">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#9E9E9E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Class}" Value="A">
                                                        <Setter Property="Background" Value="#2E7D32" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Class}" Value="B">
                                                        <Setter Property="Background" Value="#ED6C02" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Class}" Value="C">
                                                        <Setter Property="Background" Value="#D32F2F" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Class}" Value="Pending">
                                                        <Setter Property="Background" Value="#9E9E9E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Class}"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Action Required"
                                Binding="{Binding Action}"
                                Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Status Footer -->
                <Border Grid.Row="1"
                        Background="#F0F7FF"
                        
                        Padding="8"
                        VerticalAlignment="Bottom"
                        Height="30"
                        Margin="0,0,0,0">
                    <TextBlock Text="{Binding StatusMessage, FallbackValue='Loading data...'}"
                               FontSize="11"
                            Foreground="#333"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>