<UserControl x:Class="TextilePro.UI.Views.EvaluationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TextilePro.UI.Converters"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:ScoreToClassColorConverter x:Key="ScoreToClassColorConverter"/>
        <converters:ScoreToClassTextConverter x:Key="ScoreToClassTextConverter"/>
        <converters:ScoreToIndexConverter x:Key="ScoreToIndexConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,16">
            <TextBlock Text="⭐ Supplier Evaluation"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#1a1a1a"
                    VerticalAlignment="Center"/>
            <TextBlock Text="(ZDHC MRSL Compliance Scoring)"
                    FontSize="12"
                    Foreground="#888888"
                    VerticalAlignment="Center"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Supplier Selection & Records -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Background="White"
                    Padding="12"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                            Margin="0,0,0,12">
                        <TextBlock Text="🏢 Select Supplier"
                                FontWeight="Bold"
                                FontSize="14"
                                Foreground="#333333"
                                Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedSupplier}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,12"
                                  Padding="8"
                                  FontSize="13"
                                  Background="White"
                                  BorderBrush="#CCCCCC"
                                  BorderThickness="1"
                                  />
                        <Button Content="📝 New Evaluation"
                                Command="{Binding NewEvaluationCommand}"
                                Background="#0078D4"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="12,6"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Margin="0,0,0,8"/>
                        <Button Content="🔄 Refresh"
                                Command="{Binding LoadEvaluationRecordsCommand}"
                                Background="#E0E0E0"
                                Foreground="#333"
                                BorderThickness="0"
                                Padding="12,6"
                                FontWeight="SemiBold"
                                Cursor="Hand"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F0F7FF"
                           
                            Padding="8"
                            Margin="0,0,0,12">
                        <TextBlock Text="{Binding StatusMessage, FallbackValue='Select a supplier to evaluate.'}"
                                   FontSize="11"
                                Foreground="#333"
                                TextWrapping="Wrap"/>
                    </Border>

                    <Border Grid.Row="2"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                          
                            Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding EvaluationRecords}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F0F0F0"
                                                BorderThickness="0,0,0,1"
                                                Padding="4,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding SupplierName}"
                                                            FontWeight="SemiBold"
                                                            FontSize="12"/>
                                                    <TextBlock Text="{Binding EvaluationDate}"
                                                            FontSize="10"
                                                            Foreground="#888"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Score: "
                                                                FontSize="10"/>
                                                        <TextBlock Text="{Binding Score}"
                                                                FontSize="10"
                                                                FontWeight="Bold"/>
                                                        <Border Background="{Binding Class, Converter={StaticResource ScoreToClassColorConverter}}"
                                                               
                                                                Padding="6,1"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Class}"
                                                                    FontSize="9"
                                                                    Foreground="White"
                                                                    FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                    <Button Content="📝"
                                                            Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            FontSize="14"
                                                            Cursor="Hand"
                                                            ToolTip="Edit"/>
                                                    <Button Content="🗑️"
                                                            Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            FontSize="14"
                                                            Foreground="Red"
                                                            Cursor="Hand"
                                                            ToolTip="Delete"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Panel: Evaluation Form -->
            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                   
                    Background="White"
                    Padding="16"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title & Dates -->
                        <StackPanel Grid.Row="0"
                                Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedSupplier.Name, FallbackValue='Select a Supplier'}"
                                       FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="#1a1a1a"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Created: "
                                        FontSize="11"
                                        Foreground="#888"/>
                                <TextBlock Text="{Binding CreatedDateDisplay, FallbackValue='New'}"
                                        FontSize="11"
                                        Foreground="#888"/>
                                <TextBlock Text=" | Modified: "
                                        FontSize="11"
                                        Foreground="#888"
                                        Margin="12,0,0,0"/>
                                <TextBlock Text="{Binding ModifiedDateDisplay, FallbackValue='New'}"
                                        FontSize="11"
                                        Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Evaluation Header -->
                        <Border Grid.Row="1"
                                Margin="0,0,0,12"
                                Padding="0,0,0,12"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#E0E0E0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="📋 Evaluation Details"
                                            FontWeight="Bold"
                                            FontSize="14"
                                            Foreground="#333333"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                Text="Date"
                                                FontWeight="SemiBold"
                                                VerticalAlignment="Center"/>
                                        <DatePicker Grid.Column="1"
                                                SelectedDate="{Binding EvaluationDate}"
                                                Width="150"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                Text="Self Declaration"
                                                FontWeight="SemiBold"
                                                VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                ItemsSource="{Binding SelfDeclarationOptions}"
                                                  SelectedItem="{Binding SelfDeclarationStatus}"
                                                Width="150"/>
                                    </Grid>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="📎 Upload PDF(s)"
                                        Command="{Binding UploadDocumentsCommand}"
                                        Background="#E8F0FE"
                                        Foreground="#0078D4"
                                        BorderThickness="1"
                                        BorderBrush="#0078D4"
                                        Padding="12,6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        VerticalAlignment="Top"/>
                            </Grid>
                        </Border>

                        <!-- Questions -->
                        <Border Grid.Row="2"
                                Margin="0,0,0,12"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                              
                                Padding="8">
                            <ItemsControl ItemsSource="{Binding Questions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F0F0F0"
                                                BorderThickness="0,0,0,1"
                                                Padding="4,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                        Text="{Binding Id}"
                                                        Width="25"
                                                        FontWeight="Bold"
                                                        Foreground="#888"
                                                        FontSize="12"/>
                                                <StackPanel Grid.Column="1"
                                                        Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding QuestionText}"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Category}"
                                                            FontSize="10"
                                                            Foreground="#888"/>
                                                </StackPanel>
                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{Binding OptionLabels}"
                                                          SelectedIndex="{Binding SelectedScore, Converter={StaticResource ScoreToIndexConverter}}"
                                                          FontSize="12"
                                                        Padding="4"
                                                        Margin="8,0,0,0"
                                                          Background="White"
                                                        BorderBrush="#CCCCCC"
                                                        BorderThickness="1"
                                                      />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Documents -->
                        <Border Grid.Row="3"
                                Margin="0,0,0,12"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                               
                                Padding="8"
                                MaxHeight="100">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                        Text="📄 Uploaded Documents"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Foreground="#333"
                                        Margin="0,0,0,8"/>
                                <ScrollViewer Grid.Row="1"
                                        VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Documents}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#F0F0F0"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="4,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                Text="{Binding FileName}"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1"
                                                                Content="✖"
                                                                Command="{Binding DataContext.RemoveDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Foreground="Red"
                                                                Cursor="Hand"
                                                                FontSize="12"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Score & Classification -->
                        <Border Grid.Row="4"
                                Margin="0,0,0,12"
                                Background="#F0F7FF"
                                
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Total Score"
                                            FontSize="12"
                                            Foreground="#333"/>
                                    <TextBlock Text="{Binding TotalScore}"
                                            FontSize="24"
                                            FontWeight="Bold"
                                            Foreground="#0078D4"/>
                                    <TextBlock Text="/ 24"
                                            FontSize="12"
                                            Foreground="#888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="Classification"
                                            FontSize="12"
                                            Foreground="#333"/>
                                    <Border Background="{Binding Classification, Converter={StaticResource ScoreToClassColorConverter}}"
                                           
                                            Padding="12,4"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Classification, FallbackValue='-'}"
                                                FontSize="20"
                                                FontWeight="Bold"
                                                Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding ClassificationAction}"
                                            FontSize="10"
                                            Foreground="#888"
                                            TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,0">
                            <Button Content="💾 Save Evaluation"
                                    Command="{Binding SaveEvaluationCommand}"
                                    Background="#0078D4"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="20,10"
                                    Margin="0,0,12,0"
                                    Cursor="Hand"
                                    FontWeight="SemiBold"
                                    FontSize="14">
                                <Button.Resources>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                         
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>