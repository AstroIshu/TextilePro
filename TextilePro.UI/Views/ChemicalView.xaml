<UserControl x:Class="TextilePro.UI.Views.ChemicalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TextilePro.UI.Converters"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:RiskToColorConverter x:Key="RiskToColorConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,16">
            <TextBlock Text="🧪 Commodity Chemical Assignment"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#1a1a1a"
                    VerticalAlignment="Center"/>
            <TextBlock Text="(Assign ZDHC-approved chemicals to suppliers)"
                    FontSize="12"
                    Foreground="#888888"
                    VerticalAlignment="Center"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Supplier List -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Background="White"
                    Padding="12"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="🏢 Select Supplier"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="#333333"
                               Margin="0,0,0,12"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Suppliers}"
                             SelectedItem="{Binding SelectedSupplier}"
                             DisplayMemberPath="Name"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,0,0,12"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#EEEEEE"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E5F1FB"/>
                                        <Setter Property="BorderBrush" Value="#0078D4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F7FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Border Grid.Row="2"
                            Background="#F0F7FF"
                            Padding="8"
                            Margin="0,0,0,8">
                        <TextBlock Text="{Binding StatusMessage, FallbackValue='Select a supplier to view their chemicals.'}"
                                   FontSize="11"
                                   Foreground="#333"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Grid.Row="3"
                            Content="🔄 Refresh"
                            Command="{Binding LoadAllChemicalsCommand}"
                            Background="#E0E0E0"
                            Foreground="#333"
                            BorderThickness="0"
                            Padding="10,6"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- Right Panel: Chemical List -->
            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                   
                    Background="White"
                    Padding="16"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search and Sort -->
                    <StackPanel Grid.Row="0"
                            Margin="0,0,0,12">
                        <TextBlock Text="📋 All ZDHC Chemicals (88)"
                                FontWeight="Bold"
                                FontSize="14"
                                Foreground="#333333"
                                Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                   
                                     FontSize="13"
                                    Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SelectedSortOption}"
                                      Width="180"
                                      Padding="6"
                                      FontSize="12"
                                      Background="White"
                                      BorderBrush="#CCCCCC"
                                      BorderThickness="1"
                                     />
                        </Grid>
                    </StackPanel>

                    <!-- Chemical List with Checkboxes -->
                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                           
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                                <Button Content="✅ Select All"
                                        Command="{Binding SelectAllChemicalsCommand}"
                                        Background="#E8F0FE"
                                        Foreground="#0078D4"
                                        BorderThickness="0"
                                        Padding="10,4"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Margin="0,0,8,0"/>
                                <Button Content="❌ Deselect All"
                                        Command="{Binding DeselectAllChemicalsCommand}"
                                        Background="#F5F5F5"
                                        Foreground="#666"
                                        BorderThickness="0"
                                        Padding="10,4"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Margin="0,0,8,0"/>
                                <Button Content="📤 Assign Selected"
                                        Command="{Binding AssignSelectedChemicalsCommand}"
                                        Background="#0078D4"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="14,6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Margin="0,0,8,0"/>
                            </StackPanel>

                                <ScrollViewer Grid.Row="1"
                                      VerticalAlignment="Stretch"
                                      VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredChemicals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F0F0F0"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="4,6">
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          FontSize="13">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Serial}"
                                                                Width="40"
                                                                Foreground="#888"/>
                                                        <TextBlock Text="{Binding ChemicalName}"
                                                                Width="200"
                                                                FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding CAS}"
                                                                Width="130"
                                                                Foreground="#666"/>
                                                        <Border Background="{Binding RiskCategory, Converter={StaticResource RiskToColorConverter}}"
                                                              
                                                                Padding="6,2"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding RiskCategory}"
                                                                    FontSize="10"
                                                                    Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                </CheckBox>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Assigned Chemicals -->
                    <Border Grid.Row="2"
                            Margin="0,0,0,12"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Padding="8"
                            VerticalAlignment="Top"
                            MaxHeight="180">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                                <TextBlock Text="📌 Assigned to "
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Foreground="#333"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedSupplier.Name, FallbackValue='[No Supplier Selected]'}"
                                           FontWeight="Bold"
                                        FontSize="13"
                                        Foreground="#0078D4"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text=" ("
                                        FontWeight="Normal"
                                        FontSize="12"
                                        Foreground="#888"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AssignedChemicals.Count}"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Foreground="#0078D4"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text=" chemicals)"
                                        FontWeight="Normal"
                                        FontSize="12"
                                        Foreground="#888"
                                        VerticalAlignment="Center"/>
                                <Button Content="🗑️ Remove Selected"
                                        Command="{Binding DeleteSelectedChemicalsCommand}"
                                        Background="#E81123"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="14,6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Margin="20,0,0,0"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1"
                                    MaxHeight="150"
                                    VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AssignedChemicals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F0F0F0"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="4,4">
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                        VerticalAlignment="Center"
                                                        FontSize="12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Serial}"
                                                                Width="35"
                                                                Foreground="#888"/>
                                                        <TextBlock Text="{Binding ChemicalName}"
                                                                Width="180"
                                                                FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding CAS}"
                                                                Width="130"
                                                                Foreground="#666"/>
                                                        <Border Background="{Binding RiskCategory, Converter={StaticResource RiskToColorConverter}}"
                                                               
                                                                Padding="6,2"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding RiskCategory}"
                                                                    FontSize="10"
                                                                    Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                </CheckBox>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <Border Grid.Row="3"
                            Background="#F0F7FF"
                            Padding="8">
                        <TextBlock Text="{Binding StatusMessage, FallbackValue='Select a supplier to begin.'}"
                                   FontSize="11"
                                   Foreground="#333"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>